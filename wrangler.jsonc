{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-ts",
  "main": "server.mjs",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
